
<html lang="ro">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Neon Space Breaker Pro</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;700&display=swap');

        body {
            background-color: #050507;
            color: #fff;
            font-family: 'Orbitron', sans-serif;
            overflow: hidden;
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            height: 100vh;
            touch-action: none; /* Prevents scrolling while playing */
        }

        #game-container {
            position: relative;
            box-shadow: 0 0 60px rgba(0, 255, 255, 0.15);
            border-radius: 20px;
            overflow: hidden;
            border: 2px solid rgba(0, 255, 255, 0.1);
            background: #000;
        }

        canvas {
            display: block;
            cursor: none;
        }

        .hud {
            position: absolute;
            top: 20px;
            width: 100%;
            display: flex;
            justify-content: space-between;
            padding: 0 30px;
            pointer-events: none;
            font-size: 16px;
            text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
            color: #0ff;
            z-index: 10;
        }

        #overlay {
            position: absolute;
            inset: 0;
            background: rgba(0, 0, 0, 0.9);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            z-index: 100;
            text-align: center;
            padding: 20px;
            backdrop-filter: blur(5px);
        }

        .btn-glow {
            background: linear-gradient(45deg, #00f2fe, #4facfe);
            border: none;
            padding: 18px 50px;
            color: white;
            font-size: 20px;
            font-weight: bold;
            border-radius: 15px;
            cursor: pointer;
            transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            text-transform: uppercase;
            letter-spacing: 3px;
            box-shadow: 0 0 20px rgba(0, 242, 254, 0.4);
            margin-top: 25px;
        }

        .btn-glow:hover {
            transform: scale(1.1);
            box-shadow: 0 0 40px rgba(0, 242, 254, 0.7);
        }

        .shake {
            animation: shake 0.3s cubic-bezier(.36,.07,.19,.97) both;
        }

        @keyframes shake {
            10%, 90% { transform: translate3d(-2px, 0, 0); }
            20%, 80% { transform: translate3d(3px, 0, 0); }
            30%, 50%, 70% { transform: translate3d(-5px, 0, 0); }
            40%, 60% { transform: translate3d(5px, 0, 0); }
        }
    </style>
</head>
<body>

    <div id="game-container">
        <div class="hud">
            <div id="score">SCOR: 0</div>
            <div id="lives">VIEȚI: 3</div>
        </div>

        <div id="overlay">
            <h1 id="title" class="text-4xl md:text-6xl font-bold mb-4 text-transparent bg-clip-text bg-gradient-to-r from-cyan-400 to-blue-600">NEON BREAKER</h1>
            <p id="message" class="text-gray-400 mb-6 max-w-xs">Distruge toate cristalele de energie pentru a câștiga!</p>
            <button class="btn-glow" onclick="initGame()">START JOC</button>
        </div>

        <canvas id="gameCanvas"></canvas>
    </div>

    <script>
        const canvas = document.getElementById("gameCanvas");
        const ctx = canvas.getContext("2d");
        const overlay = document.getElementById("overlay");
        const scoreDisplay = document.getElementById("score");
        const livesDisplay = document.getElementById("lives");
        const container = document.getElementById("game-container");

        // Configurații
        let paddleWidth = 110;
        let paddleHeight = 14;
        let ballRadius = 7;
        let brickRowCount = 5;
        let brickColumnCount = 7;
        let brickPadding = 12;
        let brickHeight = 22;
        let brickOffsetTop = 70;
        let brickOffsetLeft = 20;

        let x, y, dx, dy, paddleX, score, lives, bricks, particles, stars;
        let isRunning = false;
        let speedMultiplier = 1;

        function resize() {
            const containerWidth = Math.min(window.innerWidth - 40, 600);
            const containerHeight = Math.min(window.innerHeight - 100, 700);
            canvas.width = containerWidth;
            canvas.height = containerHeight;
            
            // Re-calculate brick widths based on canvas size
            brickColumnCount = Math.floor(canvas.width / 85);
            brickOffsetLeft = (canvas.width - (brickColumnCount * (75 + brickPadding))) / 2;
            
            if (!isRunning) {
                paddleX = (canvas.width - paddleWidth) / 2;
            }
        }

        window.addEventListener('resize', resize);
        resize();

        // Background stars
        function createStars() {
            stars = [];
            for(let i = 0; i < 50; i++) {
                stars.push({
                    x: Math.random() * canvas.width,
                    y: Math.random() * canvas.height,
                    size: Math.random() * 2,
                    speed: Math.random() * 0.5 + 0.1
                });
            }
        }

        function initGame() {
            score = 0;
            lives = 3;
            speedMultiplier = 1;
            paddleX = (canvas.width - paddleWidth) / 2;
            createBricks();
            createStars();
            resetBall();
            particles = [];
            isRunning = true;
            overlay.style.display = "none";
            updateUI();
            requestAnimationFrame(gameLoop);
        }

        function resetBall() {
            x = canvas.width / 2;
            y = canvas.height - 50;
            // Angle randomization for start
            const angle = (Math.random() * Math.PI / 4) + Math.PI / 4; 
            const speed = 5;
            dx = speed * Math.cos(angle) * (Math.random() > 0.5 ? 1 : -1);
            dy = -speed * Math.sin(angle);
        }

        function createBricks() {
            bricks = [];
            const colors = ['#f06', '#0cf', '#0f6', '#f90', '#f0f'];
            for (let c = 0; c < brickColumnCount; c++) {
                bricks[c] = [];
                for (let r = 0; r < brickRowCount; r++) {
                    bricks[c][r] = { 
                        x: 0, 
                        y: 0, 
                        status: 1, 
                        color: colors[r % colors.length]
                    };
                }
            }
        }

        // Controls
        function handleMove(inputX) {
            if (!isRunning) return;
            const rect = canvas.getBoundingClientRect();
            const relativeX = inputX - rect.left;
            if (relativeX > 0 && relativeX < canvas.width) {
                paddleX = relativeX - paddleWidth / 2;
                // Boundary check
                if (paddleX < 0) paddleX = 0;
                if (paddleX > canvas.width - paddleWidth) paddleX = canvas.width - paddleWidth;
            }
        }

        window.addEventListener("mousemove", (e) => handleMove(e.clientX));
        window.addEventListener("touchmove", (e) => {
            handleMove(e.touches[0].clientX);
            e.preventDefault();
        }, { passive: false });

        class Particle {
            constructor(x, y, color) {
                this.x = x;
                this.y = y;
                this.color = color;
                this.size = Math.random() * 3 + 1;
                this.vx = (Math.random() - 0.5) * 8;
                this.vy = (Math.random() - 0.5) * 8;
                this.life = 1;
            }
            update() {
                this.x += this.vx;
                this.y += this.vy;
                this.life -= 0.025;
            }
            draw() {
                ctx.globalAlpha = this.life;
                ctx.fillStyle = this.color;
                ctx.beginPath();
                ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
                ctx.fill();
            }
        }

        function triggerShake() {
            container.classList.add('shake');
            setTimeout(() => container.classList.remove('shake'), 300);
        }

        function collisionDetection() {
            for (let c = 0; c < brickColumnCount; c++) {
                for (let r = 0; r < brickRowCount; r++) {
                    let b = bricks[c][r];
                    if (b.status === 1) {
                        const brickW = (canvas.width - (brickOffsetLeft * 2) - ((brickColumnCount-1) * brickPadding)) / brickColumnCount;
                        
                        // Precise collision logic
                        if (x + ballRadius > b.x && x - ballRadius < b.x + brickW && 
                            y + ballRadius > b.y && y - ballRadius < b.y + brickHeight) {
                            
                            dy = -dy;
                            b.status = 0;
                            score += 10;
                            speedMultiplier += 0.01; // Slights increase in difficulty
                            updateUI();
                            
                            // Explosion effect
                            for(let i=0; i<12; i++) particles.push(new Particle(x, y, b.color));
                            
                            // Win check
                            if (score === brickRowCount * brickColumnCount * 10) {
                                winGame();
                            }
                            return; // Handle one collision per frame
                        }
                    }
                }
            }
        }

        function updateUI() {
            scoreDisplay.innerText = `SCOR: ${score}`;
            livesDisplay.innerText = `VIEȚI: ${lives}`;
        }

        function winGame() {
            isRunning = false;
            overlay.style.display = "flex";
            document.getElementById("title").innerText = "VICTORIE!";
            document.getElementById("title").className = "text-4xl md:text-6xl font-bold mb-4 text-green-400";
            document.getElementById("message").innerText = `Ești un maestru! Scor final: ${score}`;
        }

        function gameOver() {
            isRunning = false;
            overlay.style.display = "flex";
            document.getElementById("title").innerText = "GAME OVER";
            document.getElementById("title").className = "text-4xl md:text-6xl font-bold mb-4 text-red-500";
            document.getElementById("message").innerText = "Cristalele au învins de data asta.";
        }

        function drawBackground() {
            ctx.fillStyle = "#050507";
            ctx.fillRect(0, 0, canvas.width, canvas.height);
            
            ctx.fillStyle = "rgba(255, 255, 255, 0.8)";
            stars.forEach(star => {
                ctx.beginPath();
                ctx.arc(star.x, star.y, star.size, 0, Math.PI * 2);
                ctx.fill();
                star.y += star.speed;
                if(star.y > canvas.height) star.y = 0;
            });
        }

        function drawBall() {
            ctx.save();
            ctx.shadowBlur = 15;
            ctx.shadowColor = "#fff";
            ctx.fillStyle = "#fff";
            ctx.beginPath();
            ctx.arc(x, y, ballRadius, 0, Math.PI * 2);
            ctx.fill();
            ctx.restore();
        }

        function drawPaddle() {
            ctx.save();
            ctx.shadowBlur = 20;
            ctx.shadowColor = "#0ff";
            ctx.fillStyle = "#0ff";
            ctx.beginPath();
            ctx.roundRect(paddleX, canvas.height - paddleHeight - 20, paddleWidth, paddleHeight, 7);
            ctx.fill();
            // Glow line on paddle
            ctx.strokeStyle = "rgba(255,255,255,0.5)";
            ctx.lineWidth = 2;
            ctx.stroke();
            ctx.restore();
        }

        function drawBricks() {
            const brickW = (canvas.width - (brickOffsetLeft * 2) - ((brickColumnCount-1) * brickPadding)) / brickColumnCount;
            
            for (let c = 0; c < brickColumnCount; c++) {
                for (let r = 0; r < brickRowCount; r++) {
                    if (bricks[c][r].status === 1) {
                        let brickX = c * (brickW + brickPadding) + brickOffsetLeft;
                        let brickY = r * (brickHeight + brickPadding) + brickOffsetTop;
                        bricks[c][r].x = brickX;
                        bricks[c][r].y = brickY;
                        
                        ctx.save();
                        ctx.shadowBlur = 8;
                        ctx.shadowColor = bricks[c][r].color;
                        ctx.fillStyle = bricks[c][r].color;
                        ctx.beginPath();
                        ctx.roundRect(brickX, brickY, brickW, brickHeight, 4);
                        ctx.fill();
                        
                        // Add a small highlight on bricks
                        ctx.fillStyle = "rgba(255,255,255,0.2)";
                        ctx.fillRect(brickX, brickY, brickW, 4);
                        ctx.restore();
                    }
                }
            }
        }

        function gameLoop() {
            if (!isRunning) return;

            drawBackground();
            drawBricks();
            drawBall();
            drawPaddle();
            
            // Update particles
            ctx.save();
            particles.forEach((p, i) => {
                p.update();
                p.draw();
                if(p.life <= 0) particles.splice(i, 1);
            });
            ctx.restore();

            collisionDetection();

            // Wall collisions
            if (x + dx > canvas.width - ballRadius || x + dx < ballRadius) {
                dx = -dx;
                // Add tiny particles on wall hit
                for(let i=0; i<3; i++) particles.push(new Particle(x, y, "#fff"));
            }
            if (y + dy < ballRadius) {
                dy = -dy;
            } 
            
            // Paddle collision logic
            const paddleYTop = canvas.height - paddleHeight - 20;
            if (y + ballRadius > paddleYTop && y < paddleYTop + paddleHeight) {
                if (x > paddleX && x < paddleX + paddleWidth) {
                    // Physics based bounce: angle depends on where the ball hits the paddle
                    const impactPoint = (x - (paddleX + paddleWidth / 2)) / (paddleWidth / 2);
                    const speed = Math.sqrt(dx*dx + dy*dy);
                    dx = impactPoint * 5;
                    dy = -Math.abs(dy); // Always bounce up
                    
                    triggerShake();
                    for(let i=0; i<5; i++) particles.push(new Particle(x, y, "#0ff"));
                }
            }

            // Lose life
            if (y > canvas.height) {
                lives--;
                updateUI();
                if (lives <= 0) {
                    gameOver();
                } else {
                    resetBall();
                }
            }

            x += dx * speedMultiplier;
            y += dy * speedMultiplier;

            requestAnimationFrame(gameLoop);
        }
    </script>
</body>
</html>
